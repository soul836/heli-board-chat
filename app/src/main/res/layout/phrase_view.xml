<helium314.keyboard.keyboard.phrase.PhraseView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:visibility="gone"
    android:background="@android:color/transparent"
    style="?attr/phraseViewStyle">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/phrase_category_tabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />
            </HorizontalScrollView>

            <!-- Phrase list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/phrase_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom row keyboard (same as clipboard/emoji) -->
    <helium314.keyboard.keyboard.MainKeyboardView
        android:id="@+id/phrase_bottom_row_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</helium314.keyboard.keyboard.phrase.PhraseView>
